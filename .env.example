# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_DEBUG=false
PORT=5000

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@db:5432/face_verification

# ── JWT ──────────────────────────────────────────────────────────────────────
# MUST be changed to a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, or * for development
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting (optional Redis backend) ────────────────────────────────────
# Leave empty to use in-memory limiter (not recommended for multi-process)
REDIS_URL=redis://redis:6379/0

# ── Face Recognition ─────────────────────────────────────────────────────────
# Lower = stricter (0.4–0.6 typical range). Tune for your hardware/population.
FACE_MATCH_THRESHOLD=0.5

# ── Moodle Integration ───────────────────────────────────────────────────────
MOODLE_BASE_URL=https://moodle.youruni.edu
MOODLE_CLIENT_ID=your-oauth2-client-id
MOODLE_CLIENT_SECRET=your-oauth2-client-secret
MOODLE_REDIRECT_URI=http://localhost:5000/api/moodle/callback
# Web service token with sufficient capabilities
MOODLE_WSTOKEN=your-moodle-web-service-token
